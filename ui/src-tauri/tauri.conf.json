{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MacBook Power Tools",
  "version": "1.0.0",
  "identifier": "com.user.macbook-power-tools",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MacBook Power Tools",
        "width": 720,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}